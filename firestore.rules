rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: invoices
    // Document ID: auto-generated
    // Fields:
    //   - invoiceNumber: string (required, < 50 chars)
    //   - customerName: string (required, < 100 chars)
    //   - customerAddress: string (optional, < 500 chars)
    //   - date: string (required, ISO date format)
    //   - items: list (required, max 50 items)
    //   - subtotal: number (required, >= 0)
    //   - vat: number (required, >= 0)
    //   - total: number (required, >= 0)
    //   - uid: string (required, matches auth.uid)
    //   - createdAt: string (required, ISO date-time)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "aunnun0024@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidInvoice(data) {
      return data.invoiceNumber is string && 
             data.customerName is string && 
             data.date is string &&
             data.items is list && 
             data.total is number && 
             data.uid == request.auth.uid &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /invoices/{invoiceId} {
      // Users can read their own invoices, admins can read all
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      
      // Users can create invoices for themselves
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      
      // Invoices are generally immutable once issued, but admins can update/delete
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
